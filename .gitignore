# ----------------------------------------------------------------------
# Rust / Cargo
# ----------------------------------------------------------------------
/target/
/debug/
**/*.rs.bk
*.pdb

# cargo-mutants
**/mutants.out*/

# Benchmark / profiling outputs
*.profraw
*.profdata
*.dSYM/

# ----------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.py,cover
.python-version

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.hypothesis/
.tox/
.nox/

# Coverage
.coverage
.coverage.*
htmlcov/

# Packaging / build outputs
build/
dist/
site/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Jupyter
.ipynb_checkpoints/

# ----------------------------------------------------------------------
# Editors / IDEs / OS files
# ----------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----------------------------------------------------------------------
# Logs / temp files
# ----------------------------------------------------------------------
*.log
*.tmp
*.temp

# ----------------------------------------------------------------------
# Demo and generated artifacts
# ----------------------------------------------------------------------
# Ignore generated artifacts for all demos, current and future.
demos/**/artifacts/*.json
demos/**/artifacts/*.jsonl

# Optional: if demos ever emit logs or CSVs there too, uncomment:
# demos/**/artifacts/*.log
# demos/**/artifacts/*.csv

# ----------------------------------------------------------------------
# Local env / secrets
# ----------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
